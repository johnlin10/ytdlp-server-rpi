[Unit]
Description=yt-dlp 家庭下載伺服器
After=network-online.target
Wants=network-online.target

[Service]
User=pi
WorkingDirectory=/home/pi/ytdlp-server-rpi/backend
ExecStart=/home/pi/ytdlp-server-rpi/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
